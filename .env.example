# ===========================================
# Legal RAG - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- Database (Turso) ---
# Sign up at https://turso.tech and create a database
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# --- Authentication ---
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# --- LLM API (OpenAI-compatible endpoint) ---
# HuggingFace: https://huggingface.co/settings/tokens
# Or use any OpenAI-compatible provider (Groq, Together, OpenRouter)
LLM_API_KEY="your-llm-api-key"
LLM_BASE_URL="https://router.huggingface.co/v1"
LLM_MODEL="Qwen/Qwen3.5-35B-A3B"

# --- Indian Kanoon API (optional - for case law search) ---
# Sign up at https://api.indiankanoon.org/
INDIAN_KANOON_TOKEN=""

# --- ChromaDB (optional - for RAG vector search) ---
# Leave empty to use in-memory fallback
CHROMA_PATH="./chroma-data"

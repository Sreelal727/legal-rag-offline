# ===========================================
# Legal RAG Offline - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- Database (Local SQLite) ---
# Path to the SQLite database file (default: ./data/legal-rag.db)
DATABASE_PATH="./data/legal-rag.db"
DATABASE_URL="file:./data/legal-rag.db"

# --- Authentication ---
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- LLM (Ollama - Local, Free) ---
# Install Ollama: https://ollama.com
# Pull a model: ollama pull qwen3:8b
LLM_API_KEY="ollama"
LLM_BASE_URL="http://localhost:11434/v1"
LLM_MODEL="qwen3:8b"

# --- Indian Kanoon API (optional - for case law search) ---
# Sign up at https://api.indiankanoon.org/
INDIAN_KANOON_TOKEN=""

# --- ChromaDB (optional - for RAG vector search) ---
# Leave empty to use in-memory fallback
CHROMA_PATH="./chroma-data"

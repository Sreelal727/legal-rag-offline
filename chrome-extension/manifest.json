{
  "manifest_version": 3,
  "name": "LegalDesk - eCourts Importer",
  "version": "1.0.0",
  "description": "Scrape case data from eCourts/DCMS and import directly into LegalDesk",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://services.ecourts.gov.in/*",
    "https://hcservices.ecourts.gov.in/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://services.ecourts.gov.in/*",
        "https://hcservices.ecourts.gov.in/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Organization {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  address            String?
  phone              String?
  email              String?
  gstin              String?
  registrationNumber String?
  letterheadUrl      String?
  plan               String   @default("FREE_TRIAL")
  planExpiresAt      DateTime?
  maxUsers           Int      @default(5)
  maxCases           Int      @default(50)
  maxDocuments       Int      @default(100)
  maxAiQueries       Int      @default(500)
  aiQueriesUsed      Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users              User[]
  clients            Client[]
  cases              Case[]
  documents          Document[]
  diaryEntries       DiaryEntry[]
  scheduleEvents     ScheduleEvent[]
  notices            Notice[]
  noticeTemplates    NoticeTemplate[]
  chatSessions       ChatSession[]
  auditLogs          AuditLog[]
  timeEntries        TimeEntry[]
  invoices           Invoice[]
  formatSamples      FormatSample[]
  limitationTrackers LimitationTracker[]
  documentSubmissions DocumentSubmission[]
  passwordResetTokens PasswordResetToken[]
  scrutinyReports    ScrutinyReport[]
  caseDocuments      CaseDocument[]
  caseTemplates      CaseTemplate[]
  courtFeeEntries    CourtFeeEntry[]
  feeAgreements      FeeAgreement[]
  bankOpinions       BankOpinion[]
  bankingMatters     BankingMatter[]
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  name             String
  role             String           @default("JUNIOR_ADVOCATE")
  phone            String?
  barCouncilNumber String?
  isActive         Boolean          @default(true)
  organizationId   String
  failedLoginAttempts Int           @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions         Session[]
  caseAssignments  CaseAssignment[]
  draftedNotices   Notice[]         @relation("NoticeDrafter")
  approvedNotices  Notice[]         @relation("NoticeApprover")
  courtFeeEntries  CourtFeeEntry[]
  feeAgreements    FeeAgreement[]
  bankOpinions     BankOpinion[]
  noticeApprovals  NoticeApproval[]
  chatSessions     ChatSession[]
  auditLogs        AuditLog[]
  timeEntries      TimeEntry[]
  assignedSubmissions DocumentSubmission[] @relation("AssignedSubmissions")
  createdSubmissions  DocumentSubmission[] @relation("CreatedSubmissions")
  passwordResetTokens PasswordResetToken[]
  scrutinyReports    ScrutinyReport[]
  caseDocuments      CaseDocument[]

  @@index([organizationId, isActive])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id                String       @id @default(uuid())
  name              String
  fatherHusbandName String?
  designation       String?      // S/o, D/o, W/o, R/o
  email             String?
  phone             String?
  alternatePhone    String?
  address           String?
  city              String?
  district          String?
  state             String?
  pincode           String?
  clientType        String       @default("INDIVIDUAL")
  occupation        String?
  dob               String?
  age               Int?
  panNumber         String?
  aadharNumber      String?
  gstNumber         String?
  companyName       String?      // For company clients
  cinNumber         String?      // Company Identification Number
  notes             String?
  isActive          Boolean      @default(true)
  organizationId    String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseClients       CaseClient[]
  notices           Notice[]
  limitationTrackers LimitationTracker[]
  timeEntries       TimeEntry[]
  invoices          Invoice[]
  documentSubmissions DocumentSubmission[]
  scrutinyReports   ScrutinyReport[]
  feeAgreements     FeeAgreement[]
  bankOpinions      BankOpinion[]

  @@index([organizationId, isActive])
  @@index([organizationId, clientType])
  @@index([organizationId, name])
  @@index([organizationId, updatedAt])
}

model Case {
  id              String           @id @default(uuid())
  caseNumber      String           @unique
  cnrNumber       String?          @unique
  title           String
  description     String?
  caseType        String           @default("CIVIL")
  caseSubType     String?          // PLAINT, RCP, GOP, SOP, SARFAESI, NI_ACT_138, CAVEAT, EP, APPEAL, REVISION, WRIT
  courtName       String?
  courtType       String           @default("DISTRICT_COURT")
  courtCode       String?
  stateCode       String?
  districtCode    String?
  judge           String?
  filingDate      DateTime?
  nextHearingDate DateTime?
  status          String           @default("ACTIVE")
  stage           String?          // PRE_FILING, FILED, NOTICE, WRITTEN_STATEMENT, TRIAL, ARGUMENTS, JUDGMENT, EXECUTION
  priority        String           @default("MEDIUM")
  suitValue       Float?
  courtFee        Float?
  ecourtStatus    String?
  lastSyncedAt    DateTime?
  notes           String?
  // Loan / banking fields (mostly used for EP/SARFAESI/NI Act cases)
  loanType              String?    // ATL, OD, CC, TL, HL, VL, PL, GL, MSME, AGRI, EDUCATION, SARFAESI, etc.
  loanAccountNumber     String?
  principalAmount       Float?
  interestRate          Float?     // Annual %
  penalInterestRate     Float?     // Annual % (penal/default rate)
  interestRests         String?    // MONTHLY, QUARTERLY, HALF_YEARLY, YEARLY, SIMPLE
  loanDisbursementDate  DateTime?
  loanDueDate           DateTime?
  salaryDeductionApplicable Boolean @default(false)
  cheatingClauseApplicable  Boolean @default(false)
  // Appeal tracking (when this case goes to appeal)
  appealStatus    String?   // NONE, FILED, PENDING, ALLOWED, DISMISSED, WITHDRAWN
  appealCourt     String?
  appealNumber    String?
  appealDate      DateTime?
  appealNotes     String?
  organizationId  String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseClients     CaseClient[]
  caseAssignments CaseAssignment[]
  caseEvents      CaseEvent[]
  documents       Document[]
  diaryEntries    DiaryEntry[]
  notices         Notice[]
  oppositeParties OppositeParty[]
  limitationTrackers LimitationTracker[]
  timeEntries     TimeEntry[]
  invoices        Invoice[]
  documentSubmissions DocumentSubmission[]
  scrutinyReports ScrutinyReport[]
  caseDocuments   CaseDocument[]
  courtFeeEntries CourtFeeEntry[]
  feeAgreements   FeeAgreement[]
  bankOpinions    BankOpinion[]
  revivalLetters  RevivalLetter[]
  accountStatements AccountStatement[]
  bankingMatters  BankingMatter[]
  executionPetitions ExecutionPetition[]

  @@index([organizationId, status])
  @@index([organizationId, priority])
  @@index([organizationId, updatedAt])
  @@index([organizationId, nextHearingDate])
  @@index([organizationId, filingDate])
}

model RevivalLetter {
  id             String   @id @default(uuid())
  caseId         String
  revivalDate    DateTime
  revivalType    String   @default("LETTER") // LETTER, PART_PAYMENT, ACKNOWLEDGMENT, BALANCE_CONFIRMATION
  amount         Float?   // Payment amount or acknowledged balance
  reference      String?  // Letter reference number or payment receipt no.
  newLimitationDate DateTime? // Auto-computed: revivalDate + 3 years
  notes          String?
  organizationId String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([organizationId])
}

model AccountStatement {
  id             String   @id @default(uuid())
  caseId         String
  title          String   @default("Statement of Accounts")
  asOnDate       DateTime
  principalAmount Float
  interestRate   Float    // Annual %
  penalRate      Float?
  rests          String   @default("QUARTERLY") // MONTHLY, QUARTERLY, HALF_YEARLY, YEARLY, SIMPLE
  fromDate       DateTime
  toDate         DateTime
  totalInterest  Float    @default(0)
  totalPenalInterest Float @default(0)
  totalDue       Float    @default(0)
  transactions   String?  // JSON array of {date, type, amount, description}
  schedule       String?  // JSON array of period calculations
  notes          String?
  organizationId String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([organizationId])
}

model OppositeParty {
  id                String   @id @default(uuid())
  caseId            String
  name              String
  fatherHusbandName String?
  designation       String?  // S/o, D/o, W/o
  address           String?
  city              String?
  district          String?
  state             String?
  pincode           String?
  phone             String?
  email             String?
  partyType         String   @default("RESPONDENT") // RESPONDENT, DEFENDANT, OPPOSITE_PARTY, ACCUSED
  advocateName      String?
  advocatePhone     String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  case              Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  noticeRecipients  NoticeRecipient[]

  @@index([caseId])
}

model CaseClient {
  id        String   @id @default(uuid())
  caseId    String
  clientId  String
  role      String   @default("PETITIONER")
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([caseId, clientId])
}

model CaseAssignment {
  id         String   @id @default(uuid())
  caseId     String
  userId     String
  role       String   @default("ASSOCIATE")
  assignedAt DateTime @default(now())
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
}

model CaseEvent {
  id          String   @id @default(uuid())
  caseId      String
  eventType   String   @default("HEARING")
  date        DateTime
  description String?
  outcome     String?
  nextDate    DateTime?
  createdAt   DateTime @default(now())
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, date])
}

model Document {
  id             String          @id @default(uuid())
  caseId         String?
  title          String
  fileName       String
  filePath       String
  fileType       String
  fileSize       Int
  uploadedBy     String
  extractedText  String?
  isProcessed    Boolean         @default(false)
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case           Case?           @relation(fields: [caseId], references: [id], onDelete: SetNull)
  chunks         DocumentChunk[]
  propertyDocuments PropertyDocument[]

  @@index([organizationId, createdAt])
  @@index([caseId])
  @@index([organizationId, isProcessed])
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  content    String
  chunkIndex Int
  metadata   String?
  chromaId   String?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model DiaryEntry {
  id             String    @id @default(uuid())
  caseId         String
  date           DateTime
  courtName      String?
  caseNumber     String?
  description    String?
  stage          String?
  nextDate       DateTime?
  notes          String?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([caseId, date])
}

model ScheduleEvent {
  id             String    @id @default(uuid())
  title          String
  description    String?
  date           DateTime
  endDate        DateTime?
  eventType      String    @default("HEARING")
  caseId         String?
  isAllDay       Boolean   @default(false)
  reminder       Boolean   @default(false)
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([caseId])
}

model LimitationTracker {
  id              String    @id @default(uuid())
  caseId          String?
  clientId        String?
  title           String
  description     String?
  category        String    @default("GENERAL")
  accrualDate     DateTime
  limitationDays  Int
  deadlineDate    DateTime
  extensionDays   Int       @default(0)
  extensionReason String?
  status          String    @default("ACTIVE")
  alertDays       Int       @default(30)
  notes           String?
  createdBy       String
  organizationId  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case            Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, deadlineDate])
  @@index([caseId])
  @@index([clientId])
}

model NoticeTemplate {
  id             String   @id @default(uuid())
  name           String
  description    String?
  category       String?
  content        String
  variables      String?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notices        Notice[]

  @@index([organizationId, isActive])
}

model Notice {
  id             String           @id @default(uuid())
  templateId     String?
  caseId         String?
  clientId       String?
  title          String
  content        String
  status         String           @default("DRAFT")
  draftedBy      String
  approvedBy     String?
  sentAt         DateTime?
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template       NoticeTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  case           Case?            @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  drafter        User             @relation("NoticeDrafter", fields: [draftedBy], references: [id])
  approver       User?            @relation("NoticeApprover", fields: [approvedBy], references: [id])
  noticeType     String?
  approvals      NoticeApproval[]
  recipients     NoticeRecipient[]
  replies        NoticeReply[]

  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@index([caseId])
  @@index([clientId])
  @@index([templateId])
}

model NoticeApproval {
  id        String   @id @default(uuid())
  noticeId  String
  userId    String
  action    String
  comments  String?
  createdAt DateTime @default(now())
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([noticeId])
  @@index([userId])
}

model ChatSession {
  id             String        @id @default(uuid())
  userId         String
  title          String        @default("New Chat")
  caseId         String?
  documentId     String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]

  @@index([organizationId, userId, updatedAt])
  @@index([caseId])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  sources   String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  action         String
  entity         String
  entityId       String?
  details        String?
  ipAddress      String?
  organizationId String
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([entity, entityId])
}

model TimeEntry {
  id             String   @id @default(uuid())
  userId         String
  caseId         String?
  clientId       String?
  description    String
  date           DateTime
  hours          Float
  rate           Float    @default(0)
  amount         Float    @default(0)
  isBilled       Boolean  @default(false)
  invoiceId      String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id])
  case           Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  invoice        Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, userId, date])
  @@index([caseId])
  @@index([clientId])
  @@index([invoiceId])
  @@index([isBilled])
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  clientId       String
  caseId         String?
  subtotal       Float         @default(0)
  gstRate        Float         @default(18)
  gstAmount      Float         @default(0)
  totalAmount    Float         @default(0)
  status         String        @default("DRAFT")
  dueDate        DateTime?
  paidDate       DateTime?
  notes          String?
  createdBy      String
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client        @relation(fields: [clientId], references: [id])
  case           Case?         @relation(fields: [caseId], references: [id], onDelete: SetNull)
  timeEntries    TimeEntry[]
  invoiceItems   InvoiceItem[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([clientId])
  @@index([caseId])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  rate        Float
  amount      Float
  sacCode     String? @default("998211")
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model FormatSample {
  id             String   @id @default(uuid())
  name           String
  category       String
  subcategory    String?
  description    String?
  textContent    String
  filePath       String
  fileName       String
  fileSize       Int      @default(0)
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive, category])
  @@index([organizationId, updatedAt])
}

model DocumentSubmission {
  id             String    @id @default(uuid())
  caseId         String?
  clientId       String?
  title          String
  description    String?
  documentType   String    @default("PLEADING")
  status         String    @default("TODO")
  priority       String    @default("MEDIUM")
  dueDate        DateTime?
  assignedTo     String?
  courtName      String?
  remarks        String?
  sortOrder      Int       @default(0)
  createdBy      String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case           Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignee       User?     @relation("AssignedSubmissions", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator        User      @relation("CreatedSubmissions", fields: [createdBy], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([caseId])
  @@index([clientId])
  @@index([assignedTo])
}

model ScrutinyReport {
  id                String   @id @default(uuid())
  title             String
  referenceNumber   String?
  bankName          String?
  branchName        String?
  borrowerName      String?
  propertyAddress   String?
  surveyNumbers     String?
  status            String   @default("DRAFT")
  processingStatus  String?
  formatSampleId    String?
  caseId            String?
  clientId          String?
  createdBy         String
  organizationId    String
  reportContent     String?
  reportNotes       String?
  verificationData  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case              Case?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client            Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  creator           User         @relation(fields: [createdBy], references: [id])
  propertyDocuments PropertyDocument[]
  deedChainNodes    DeedChainNode[]

  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@index([caseId])
  @@index([clientId])
}

model PropertyDocument {
  id                 String   @id @default(uuid())
  scrutinyReportId   String
  documentId         String?
  pageRange          String?
  documentType       String   @default("UNKNOWN")
  classification     String?
  extractedFields    String?
  extractedText      String?
  language           String?  @default("en")
  ocrRequired        Boolean  @default(false)
  ocrCompleted       Boolean  @default(false)
  sortOrder          Int      @default(0)
  notes              String?
  verificationStatus String?  @default("PENDING")
  verificationNotes  String?
  filePath           String?
  fileName           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  scrutinyReport     ScrutinyReport @relation(fields: [scrutinyReportId], references: [id], onDelete: Cascade)
  document           Document?      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  deedChainNodes     DeedChainNode[]

  @@index([scrutinyReportId, sortOrder])
  @@index([documentId])
}

model DeedChainNode {
  id                 String    @id @default(uuid())
  scrutinyReportId   String
  propertyDocumentId String?
  documentNumber     String?
  registrationYear   Int?
  sroName            String?
  executionDate      DateTime?
  registrationDate   DateTime?
  deedType           String?
  grantor            String?
  grantee            String?
  surveyNumbers      String?
  area               Float?
  areaUnit           String?   @default("cents")
  areaOriginal       String?
  consideration      Float?
  stampDuty          Float?
  parentNodeIds      String?
  referencedDeedNos  String?
  isMissing          Boolean   @default(false)
  isLatest           Boolean   @default(false)
  chainDepth         Int       @default(0)
  verificationFlags  String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  scrutinyReport     ScrutinyReport   @relation(fields: [scrutinyReportId], references: [id], onDelete: Cascade)
  propertyDocument   PropertyDocument? @relation(fields: [propertyDocumentId], references: [id], onDelete: SetNull)

  @@index([scrutinyReportId])
  @@index([propertyDocumentId])
}

model NoticeRecipient {
  id                String    @id @default(uuid())
  noticeId          String
  oppositePartyId   String?
  recipientName     String
  recipientAddress  String
  recipientCity     String?
  recipientState    String?
  recipientPincode  String?
  deliveryMethod    String    @default("REGISTERED_POST")
  trackingNumber    String?
  sentDate          DateTime?
  deliveredDate     DateTime?
  deliveryStatus    String    @default("PENDING")
  adCardUrl         String?
  receiptUrl        String?
  returnReason      String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  notice            Notice         @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  oppositeParty     OppositeParty? @relation(fields: [oppositePartyId], references: [id], onDelete: SetNull)
  replies           NoticeReply[]

  @@index([noticeId])
  @@index([oppositePartyId])
}

model NoticeReply {
  id            String    @id @default(uuid())
  noticeId      String
  recipientId   String?
  replyDate     DateTime
  replyContent  String?
  documentPath  String?
  documentName  String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  notice        Notice          @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  recipient     NoticeRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([noticeId])
  @@index([recipientId])
}

model CaseTemplate {
  id              String   @id @default(uuid())
  name            String
  category        String
  documentType    String
  description     String?
  content         String
  variables       String?
  courtType       String?
  isActive        Boolean  @default(true)
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseDocuments   CaseDocument[]

  @@index([organizationId, isActive, category])
}

model CaseDocument {
  id              String    @id @default(uuid())
  caseId          String
  documentType    String
  title           String
  content         String
  templateId      String?
  status          String    @default("DRAFT")
  filedDate       DateTime?
  filingNumber    String?
  courtName       String?
  notes           String?
  generatedBy     String
  organizationId  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  case            Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  template        CaseTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator         User          @relation(fields: [generatedBy], references: [id])

  @@index([organizationId, status])
  @@index([caseId])
  @@index([templateId])
}

model CourtFeeEntry {
  id             String   @id @default(uuid())
  caseId         String
  amount         Float
  feeType        String   @default("COURT_FEE") // COURT_FEE, PROCESS_FEE, ADVOCATE_FEE, MISC
  description    String?
  paidDate       DateTime?
  receiptNumber  String?
  isPaid         Boolean  @default(false)
  organizationId String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        User     @relation(fields: [createdBy], references: [id])

  @@index([organizationId, isPaid])
  @@index([caseId])
}

model FeeAgreement {
  id             String   @id @default(uuid())
  clientId       String
  caseId         String?
  agreementDate  DateTime
  totalFee       Float
  retainerFee    Float    @default(0)
  appearanceFee  Float    @default(0)
  successFee     Float    @default(0)
  paymentTerms   String?
  notes          String?
  status         String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  organizationId String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  case           Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        User     @relation(fields: [createdBy], references: [id])

  @@index([organizationId, status])
  @@index([clientId])
  @@index([caseId])
}

model BankOpinion {
  id             String   @id @default(uuid())
  bankName       String
  branchName     String?
  borrowerName   String
  propertyAddress String?
  loanAmount     Float?
  content        String?  // Generated opinion text
  status         String   @default("DRAFT") // DRAFT, REVIEW, FINALIZED
  caseId         String?
  clientId       String?
  createdBy      String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  case           Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        User     @relation(fields: [createdBy], references: [id])

  @@index([organizationId, status])
  @@index([caseId])
  @@index([clientId])
}

// ============================================================
// Banking Matter Pipeline
// ============================================================
model BankingMatter {
  id              String   @id @default(uuid())
  title           String   // e.g., "SIB Kottayi vs. Rajan K."
  caseId          String?  // linked after case is created
  bankClientId    String?  // Client (bank) acting as petitioner/plaintiff
  suitType        String   @default("OS") // OS or CS
  currentStage    String   @default("DOCUMENTS") // DOCUMENTS, NOTICE, MEDIATION, PLAINT, FILING_BUNDLE, FILED, TRIAL, DECREE, EXECUTION
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, ABANDONED
  extractedData   String?  // JSON — consolidated data card from AI extraction
  courtName       String?
  courtType       String?  // Munsiff, Sub-Court, District Court, Commercial Court
  notes           String?
  organizationId  String
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  case            Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  matterDocuments MatterDocument[]

  @@index([organizationId, status])
  @@index([organizationId, currentStage])
  @@index([organizationId, updatedAt])
  @@index([caseId])
}

model MatterDocument {
  id              String    @id @default(uuid())
  matterId        String
  documentType    String    // DEMAND_NOTICE, OS_PLAINT, CS_PLAINT, FACT_AFFIDAVIT, etc.
  title           String
  content         String    // Generated document text
  status          String    @default("GENERATED") // GENERATED, UNDER_REVIEW, APPROVED
  templateUsed    String?   // Template name used to generate
  sortOrder       Int       @default(0)
  approvedAt      DateTime?
  approvedBy      String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  matter          BankingMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId, sortOrder])
  @@index([matterId, documentType])
}

model ExecutionPetition {
  id                    String   @id @default(uuid())
  caseId                String
  epNumber              String?  // E.P. No. (assigned by court after filing)
  epType                String   // EP_ARREST, EP_ATTACHMENT_SALE, EP_SALE, EP_TRANSFER, EP_DELIVERY
  decreeDate            DateTime?
  decretalAmount        Float?
  costAwarded           Float?
  postDecreeInterestRate Float?
  decreeContent         String?  // Uploaded decree text (AI-extracted)
  generatedContent      String?  // Generated EP petition text
  affidavitContent      String?  // Generated EP affidavit text
  propertySchedule      String?  // JSON — property details for A&S/Sale EPs
  previousEPs           String?  // JSON — history of prior EPs
  status                String   @default("DRAFT") // DRAFT, UNDER_REVIEW, APPROVED, FILED
  organizationId        String
  createdBy             String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  case                  Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([organizationId, status])
}

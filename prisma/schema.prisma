generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Organization {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  address            String?
  phone              String?
  email              String?
  gstin              String?
  registrationNumber String?
  letterheadUrl      String?
  plan               String   @default("FREE_TRIAL")
  planExpiresAt      DateTime?
  maxUsers           Int      @default(5)
  maxCases           Int      @default(50)
  maxDocuments       Int      @default(100)
  maxAiQueries       Int      @default(500)
  aiQueriesUsed      Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users              User[]
  clients            Client[]
  cases              Case[]
  documents          Document[]
  diaryEntries       DiaryEntry[]
  scheduleEvents     ScheduleEvent[]
  notices            Notice[]
  noticeTemplates    NoticeTemplate[]
  chatSessions       ChatSession[]
  auditLogs          AuditLog[]
  timeEntries        TimeEntry[]
  invoices           Invoice[]
  formatSamples      FormatSample[]
  limitationTrackers LimitationTracker[]
  documentSubmissions DocumentSubmission[]
  passwordResetTokens PasswordResetToken[]
  scrutinyReports    ScrutinyReport[]
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  name             String
  role             String           @default("JUNIOR_ADVOCATE")
  phone            String?
  barCouncilNumber String?
  isActive         Boolean          @default(true)
  organizationId   String
  failedLoginAttempts Int           @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions         Session[]
  caseAssignments  CaseAssignment[]
  draftedNotices   Notice[]         @relation("NoticeDrafter")
  approvedNotices  Notice[]         @relation("NoticeApprover")
  noticeApprovals  NoticeApproval[]
  chatSessions     ChatSession[]
  auditLogs        AuditLog[]
  timeEntries      TimeEntry[]
  assignedSubmissions DocumentSubmission[] @relation("AssignedSubmissions")
  createdSubmissions  DocumentSubmission[] @relation("CreatedSubmissions")
  passwordResetTokens PasswordResetToken[]
  scrutinyReports    ScrutinyReport[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Client {
  id             String       @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  clientType     String       @default("INDIVIDUAL")
  panNumber      String?
  aadharNumber   String?
  gstNumber      String?
  notes          String?
  isActive       Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseClients    CaseClient[]
  notices        Notice[]
  limitationTrackers LimitationTracker[]
  timeEntries    TimeEntry[]
  invoices       Invoice[]
  documentSubmissions DocumentSubmission[]
  scrutinyReports ScrutinyReport[]
}

model Case {
  id              String           @id @default(uuid())
  caseNumber      String           @unique
  cnrNumber       String?          @unique
  title           String
  description     String?
  caseType        String           @default("CIVIL")
  courtName       String?
  courtType       String           @default("DISTRICT_COURT")
  courtCode       String?
  stateCode       String?
  districtCode    String?
  judge           String?
  filingDate      DateTime?
  nextHearingDate DateTime?
  status          String           @default("ACTIVE")
  priority        String           @default("MEDIUM")
  ecourtStatus    String?
  lastSyncedAt    DateTime?
  notes           String?
  organizationId  String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseClients     CaseClient[]
  caseAssignments CaseAssignment[]
  caseEvents      CaseEvent[]
  documents       Document[]
  diaryEntries    DiaryEntry[]
  notices         Notice[]
  limitationTrackers LimitationTracker[]
  timeEntries     TimeEntry[]
  invoices        Invoice[]
  documentSubmissions DocumentSubmission[]
  scrutinyReports ScrutinyReport[]
}

model CaseClient {
  id        String   @id @default(uuid())
  caseId    String
  clientId  String
  role      String   @default("PETITIONER")
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([caseId, clientId])
}

model CaseAssignment {
  id         String   @id @default(uuid())
  caseId     String
  userId     String
  role       String   @default("ASSOCIATE")
  assignedAt DateTime @default(now())
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
}

model CaseEvent {
  id          String   @id @default(uuid())
  caseId      String
  eventType   String   @default("HEARING")
  date        DateTime
  description String?
  outcome     String?
  nextDate    DateTime?
  createdAt   DateTime @default(now())
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Document {
  id             String          @id @default(uuid())
  caseId         String?
  title          String
  fileName       String
  filePath       String
  fileType       String
  fileSize       Int
  uploadedBy     String
  extractedText  String?
  isProcessed    Boolean         @default(false)
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case           Case?           @relation(fields: [caseId], references: [id], onDelete: SetNull)
  chunks         DocumentChunk[]
  propertyDocuments PropertyDocument[]
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  content    String
  chunkIndex Int
  metadata   String?
  chromaId   String?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DiaryEntry {
  id             String    @id @default(uuid())
  caseId         String
  date           DateTime
  courtName      String?
  caseNumber     String?
  description    String?
  stage          String?
  nextDate       DateTime?
  notes          String?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model ScheduleEvent {
  id             String    @id @default(uuid())
  title          String
  description    String?
  date           DateTime
  endDate        DateTime?
  eventType      String    @default("HEARING")
  caseId         String?
  isAllDay       Boolean   @default(false)
  reminder       Boolean   @default(false)
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model LimitationTracker {
  id              String    @id @default(uuid())
  caseId          String?
  clientId        String?
  title           String
  description     String?
  category        String    @default("GENERAL")
  accrualDate     DateTime
  limitationDays  Int
  deadlineDate    DateTime
  extensionDays   Int       @default(0)
  extensionReason String?
  status          String    @default("ACTIVE")
  alertDays       Int       @default(30)
  notes           String?
  createdBy       String
  organizationId  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case            Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model NoticeTemplate {
  id             String   @id @default(uuid())
  name           String
  description    String?
  category       String?
  content        String
  variables      String?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notices        Notice[]
}

model Notice {
  id             String           @id @default(uuid())
  templateId     String?
  caseId         String?
  clientId       String?
  title          String
  content        String
  status         String           @default("DRAFT")
  draftedBy      String
  approvedBy     String?
  sentAt         DateTime?
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template       NoticeTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  case           Case?            @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  drafter        User             @relation("NoticeDrafter", fields: [draftedBy], references: [id])
  approver       User?            @relation("NoticeApprover", fields: [approvedBy], references: [id])
  approvals      NoticeApproval[]
}

model NoticeApproval {
  id        String   @id @default(uuid())
  noticeId  String
  userId    String
  action    String
  comments  String?
  createdAt DateTime @default(now())
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model ChatSession {
  id             String        @id @default(uuid())
  userId         String
  title          String        @default("New Chat")
  caseId         String?
  documentId     String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  sources   String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  action         String
  entity         String
  entityId       String?
  details        String?
  ipAddress      String?
  organizationId String
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model TimeEntry {
  id             String   @id @default(uuid())
  userId         String
  caseId         String?
  clientId       String?
  description    String
  date           DateTime
  hours          Float
  rate           Float    @default(0)
  amount         Float    @default(0)
  isBilled       Boolean  @default(false)
  invoiceId      String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id])
  case           Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  invoice        Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  clientId       String
  caseId         String?
  subtotal       Float         @default(0)
  gstRate        Float         @default(18)
  gstAmount      Float         @default(0)
  totalAmount    Float         @default(0)
  status         String        @default("DRAFT")
  dueDate        DateTime?
  paidDate       DateTime?
  notes          String?
  createdBy      String
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client        @relation(fields: [clientId], references: [id])
  case           Case?         @relation(fields: [caseId], references: [id], onDelete: SetNull)
  timeEntries    TimeEntry[]
  invoiceItems   InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  rate        Float
  amount      Float
  sacCode     String? @default("998211")
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model FormatSample {
  id             String   @id @default(uuid())
  name           String
  category       String
  subcategory    String?
  description    String?
  textContent    String
  filePath       String
  fileName       String
  fileSize       Int      @default(0)
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model DocumentSubmission {
  id             String    @id @default(uuid())
  caseId         String?
  clientId       String?
  title          String
  description    String?
  documentType   String    @default("PLEADING")
  status         String    @default("TODO")
  priority       String    @default("MEDIUM")
  dueDate        DateTime?
  assignedTo     String?
  courtName      String?
  remarks        String?
  sortOrder      Int       @default(0)
  createdBy      String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case           Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignee       User?     @relation("AssignedSubmissions", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator        User      @relation("CreatedSubmissions", fields: [createdBy], references: [id])
}

model ScrutinyReport {
  id                String   @id @default(uuid())
  title             String
  referenceNumber   String?
  bankName          String?
  branchName        String?
  borrowerName      String?
  propertyAddress   String?
  surveyNumbers     String?
  status            String   @default("DRAFT")
  processingStatus  String?
  formatSampleId    String?
  caseId            String?
  clientId          String?
  createdBy         String
  organizationId    String
  reportContent     String?
  reportNotes       String?
  verificationData  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  case              Case?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  client            Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  creator           User         @relation(fields: [createdBy], references: [id])
  propertyDocuments PropertyDocument[]
  deedChainNodes    DeedChainNode[]
}

model PropertyDocument {
  id                 String   @id @default(uuid())
  scrutinyReportId   String
  documentId         String?
  pageRange          String?
  documentType       String   @default("UNKNOWN")
  classification     String?
  extractedFields    String?
  extractedText      String?
  language           String?  @default("en")
  ocrRequired        Boolean  @default(false)
  ocrCompleted       Boolean  @default(false)
  sortOrder          Int      @default(0)
  notes              String?
  verificationStatus String?  @default("PENDING")
  verificationNotes  String?
  filePath           String?
  fileName           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  scrutinyReport     ScrutinyReport @relation(fields: [scrutinyReportId], references: [id], onDelete: Cascade)
  document           Document?      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  deedChainNodes     DeedChainNode[]
}

model DeedChainNode {
  id                 String    @id @default(uuid())
  scrutinyReportId   String
  propertyDocumentId String?
  documentNumber     String?
  registrationYear   Int?
  sroName            String?
  executionDate      DateTime?
  registrationDate   DateTime?
  deedType           String?
  grantor            String?
  grantee            String?
  surveyNumbers      String?
  area               Float?
  areaUnit           String?   @default("cents")
  areaOriginal       String?
  consideration      Float?
  stampDuty          Float?
  parentNodeIds      String?
  referencedDeedNos  String?
  isMissing          Boolean   @default(false)
  isLatest           Boolean   @default(false)
  chainDepth         Int       @default(0)
  verificationFlags  String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  scrutinyReport     ScrutinyReport   @relation(fields: [scrutinyReportId], references: [id], onDelete: Cascade)
  propertyDocument   PropertyDocument? @relation(fields: [propertyDocumentId], references: [id], onDelete: SetNull)
}
